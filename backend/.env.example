# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# CORS (use https://scraper.cushlabs.ai in production)
CORS_ORIGINS=http://localhost:3000

# Rate limiting (Upstash Redis, REST API).
# Both must be set to activate distributed rate limiting on mutating /api/v1
# endpoints. If unset, the limiter falls back to in-memory (dev only) and the
# middleware fails open. Get these from the Upstash console: Database > REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Environment
ENVIRONMENT=development
PORT=10000

# Sentry
SENTRY_DSN=

# Feature Flags
ENABLE_BATCH_CRAWLS=false
ENABLE_SEO_AUDIT=false
ENABLE_LLM=false
ENABLE_SELECTOR_SCRAPING=false
